{
  "name": "seiger/scommerce",
  "license": "GPL-3.0",
  "type": "evolutioncms-module",
  "description": "E-commerce tools package for Evolution CMS.",
  "keywords": [
    "evocms",
    "evolution-cms",
    "e-commerce",
    "ecommerce",
    "shop",
    "catalog",
    "online-store",
    "ecommerce-tools"
  ],
  "authors": [
    {
      "name": "Serhii Korneliuk",
      "email": "info@seigerit.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "evolution-cms/evolution": "^3.5.7",
    "seiger/sgallery": "^1.3",
    "seiger/stask": "^1.0 || ^2.0"
  },
  "autoload": {
    "psr-4": {
      "Seiger\\sCommerce\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Seiger\\sCommerce\\sCommerceServiceProvider"
      ],
      "aliases": {
        "sCommerce": "Seiger\\sCommerce\\Facades\\sCommerce"
      }
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php artisan cache:clear"
    ]
  }
}
